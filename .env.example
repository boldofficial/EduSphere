# =============================================
# PRODUCTION ENVIRONMENT TEMPLATE
# =============================================
# EduSphere uses self-hosted PostgreSQL (via PgBouncer)
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or real credentials to version control

# =============================================
# POSTGRESQL / DATABASE
# =============================================
POSTGRES_DB=registra_db
POSTGRES_USER=registra_admin
POSTGRES_PASSWORD=your-secure-password-here

# =============================================
# REDIS / CELERY
# =============================================
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================
# CLOUDFLARE R2 STORAGE
# =============================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.your-domain.com

# =============================================
# DJANGO CONFIGURATION
# =============================================
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=false
ALLOWED_HOSTS=myregistra.net,*.myregistra.net
CORS_ALLOWED_ORIGINS=https://myregistra.net,https://*.myregistra.net
CSRF_TRUSTED_ORIGINS=https://myregistra.net,https://*.myregistra.net

# =============================================
# NEXT.JS CONFIGURATION
# =============================================
NODE_ENV=production
NEXT_PUBLIC_ROOT_DOMAIN=myregistra.net
NEXT_PUBLIC_API_URL=https://api.myregistra.net
DJANGO_API_URL=http://backend:8000

# =============================================
# OPTIONAL: AI FEATURES
# =============================================
GEMINI_API_KEY=your-gemini-api-key

# =============================================
# SECURITY & AUTHENTICATION
# =============================================
PASSWORD_SALT=your-random-salt-here

# =============================================
# OPTIONAL: UPSTASH REDIS (for rate limiting - recommended for production)
# =============================================
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# =============================================
# OPTIONAL: ANALYTICS & ERROR TRACKING
# =============================================
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx